{
  "name": "mind-blog-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "cy:open": "cypress open --e2e",
    "cy:run": "cypress run --e2e",
    "test:e2e": "start-server-and-test 'VITE_MOCKOON_URL=http://mockoon.test VITE_NEWS_API=http://news.test VITE_NEWS_API_KEY=test vite --host 127.0.0.1 --strictPort' http://127.0.0.1:5173 cy:run",
    "check": "ncu",
    "check:update": "ncu -u",
    "check:interactive": "ncu --interactive",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "data-fns": "^1.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.15.1",
    "react-toastify": "^11.1.0",
    "remark-gfm": "^4.0.1",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/format": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "chromatic": "^16.10.1",
    "conventional-changelog-atom": "^5.1.0",
    "cypress": "^15.19.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.11",
    "storybook": "^10.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6",
    "vitest-localstorage-mock": "^0.1.2"
  }
}
